{
	"name": "Mecanica",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2.5.7": {
			"configureZshAsDefaultShell": true
		},
		//		"ghcr.io/devcontainers/features/docker-in-docker:2.16.1": {},
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1.9.1": {},
		//    "ghcr.io/devcontainers/features/maven:1": {},
		"ghcr.io/devcontainers/features/git:1.3.5": {},
		"ghcr.io/devcontainers/features/node:1.7.1": {},
		"ghcr.io/devcontainers/features/python:1.8.0": {},
		"ghcr.io/devcontainers/features/terraform:1.4.2": {},
		"ghcr.io/devcontainers/features/kubectl-helm-minikube:1.3.1": {},
		"ghcr.io/devcontainers/features/aws-cli:1": {},
		"ghcr.io/devcontainers/features/java:1": {
			"installMaven": true
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"vscjava.vscode-java-pack",
				"vmware.vscode-spring-boot",
				"Pivotal.vscode-spring-boot",
				"vscjava.vscode-java-dependency",
				"vscjava.vscode-java-test"
			],
			"settings": {
				"java.configuration.updateBuildConfiguration": "automatic",
			}
		}
	},
	"forwardPorts": [
		8080,
		8081
	],
	"postCreateCommand": "mvn clean install -DskipTests",
	"remoteUser": "vscode"
}